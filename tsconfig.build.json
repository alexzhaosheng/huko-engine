{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node16",
    "module": "node16"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
